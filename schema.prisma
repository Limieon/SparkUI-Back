datasource db {
    provider = "sqlite"
    url      = "file:db.sqlite"
}

generator client {
    provider             = "prisma-client-py"
    recursive_type_depth = 5
}

// ---> Checkpoint <--- //
// ------> Base Data <------ //
model Checkpoint {
    handle String @id @unique
    name   String

    created_at   DateTime
    last_updated DateTime

    civitai_id Int?

    GenerationData      Txt2Img_GenerationData[]
    CheckpointVariation CheckpointVariation[]
}

model CheckpointVariation {
    handle     String  @id @unique
    name       String
    baseModel  String
    file       String?
    previewUrl String

    created_at DateTime

    civitai_id Int?

    // Foreign keys
    checkpointHandle String

    // Relations
    checkpoint Checkpoint @relation(fields: [checkpointHandle], references: [handle])

    GenerationData Txt2Img_GenerationData[]
}

// ---> Lora <--- //
model Lora {
    id     Int    @id @unique @default(autoincrement())
    handle String @unique
    name   String

    LoraWeight LoraWeight[]
}

model LoraVersion {
    id        Int    @id @unique @default(autoincrement())
    handle    String @unique
    name      String
    baseModel String

    // Foreign Keys
    civitAIOriginId Int?

    LoraWeight LoraWeight[]
    origin     CivitAIOrigin? @relation(fields: [civitAIOriginId], references: [id])
}

model LoraWeight {
    id Int @id @unique @default(autoincrement())

    weight Float

    // Foreign keys
    loraId        Int
    loraVersionId Int

    GenerationDataId Int?

    // Relations
    lora           Lora                    @relation(fields: [loraId], references: [id])
    loraVersion    LoraVersion             @relation(fields: [loraVersionId], references: [id])
    GenerationData Txt2Img_GenerationData? @relation(fields: [GenerationDataId], references: [id])
}

// ---> Embedding <--- //
model Embedding {
    id     Int    @id @unique @default(autoincrement())
    handle String @unique
    name   String

    // Foreign keys
    GenerationDataId Int?

    // Relations
    GenerationData Txt2Img_GenerationData? @relation(fields: [GenerationDataId], references: [id])
}

model EmbeddingVersion {
    id               Int                     @id @unique @default(autoincrement())
    handle           String                  @unique
    name             String
    GenerationData   Txt2Img_GenerationData? @relation(fields: [GenerationDataId], references: [id])
    GenerationDataId Int?
}

// ---> Embedding <--- //
model VAE {
    id             Int                      @id @unique @default(autoincrement())
    handle         String                   @unique
    name           String
    GenerationData Txt2Img_GenerationData[]
}

model VAEVersion {
    id             Int                      @id @unique @default(autoincrement())
    handle         String                   @unique
    name           String
    GenerationData Txt2Img_GenerationData[]
}

/// ---> Origins <--- //
model CivitAIOrigin {
    id          Int @id @unique @default(autoincrement())
    baseId      Int
    variationId Int

    url         String
    LoraVersion LoraVersion[]
}

// ------> User Data <------ //
// ---> Image <--- //
model Image {
    id             Int              @id @unique @default(autoincrement())
    fileName       String
    created_at     DateTime         @default(now())
    GeneratedImage GeneratedImage[]
    UploadedImage  UploadedImage[]

    // Foreign keys
    imageGroupId Int?

    // Relations
    Board ImageGroup? @relation(fields: [imageGroupId], references: [id])
}

model GeneratedImage {
    id Int @id @unique @default(autoincrement())

    imageId          Int?
    generationDataId Int

    image          Image?                 @relation(fields: [imageId], references: [id])
    generationData Txt2Img_GenerationData @relation(fields: [generationDataId], references: [id])
    QueueItem      QueueItem[]
}

model Txt2Img_GenerationData {
    id Int @id @unique @default(autoincrement())

    prompt              String @default("")
    negativePrompt      String @default("")
    stylePrompt         String @default("")
    negativeStylePrompt String @default("")

    steps     Int
    cfg_scale Float
    seed      Int
    width     Int
    height    Int

    // Foreign keys
    checkpointHandle          String
    checkpointVariationHandle String
    vaeID                     Int    @default(-1)
    vaeVersionId              Int    @default(-1)
    sampler                   String
    precision                 String

    // Relations
    checkpoint          Checkpoint          @relation(fields: [checkpointHandle], references: [handle])
    checkpointVariation CheckpointVariation @relation(fields: [checkpointVariationHandle], references: [handle])
    vae                 VAE                 @relation(fields: [vaeID], references: [id])
    vaeVersion          VAEVersion          @relation(fields: [vaeVersionId], references: [id])

    generatedImage   GeneratedImage[]
    embedding        Embedding[]
    embeddingVersion EmbeddingVersion[]
    loras            LoraWeight[]

    @@map("GenerationData")
}

model UploadedImage {
    id Int @id @unique @default(autoincrement())

    imageId Int

    image Image @relation(fields: [imageId], references: [id])
}

// ---> Boards <--- //
model ImageGroup {
    id   Int    @id @unique @default(autoincrement())
    name String

    images Image[]
}

// ---> Queue <--- //
model QueueItem {
    id Int @id @unique @default(autoincrement())

    status     Int
    startedAt  DateTime
    updatedAt  DateTime?
    finishedAt DateTime?

    // Foreign keys 
    generatedImage GeneratedImage @relation(fields: [generatedImageId], references: [id])

    // Relations
    generatedImageId Int
}
